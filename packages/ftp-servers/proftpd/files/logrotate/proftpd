/var/log/proftpd/proftpd.log
/var/log/proftpd/controls.log
{
    weekly
    missingok
    rotate 7
    compress
    delaycompress
    notifempty
    create 640 root adm
    sharedscripts
    postrotate
        # reload could be not sufficient for all logs, a restart is safer
        /bin/systemctl restart proftpd.service 2>/dev/null >/dev/null || true
    endscript
}

/var/log/xferlog
/var/log/proftpd/xferlog
/var/log/proftpd/xferreport
{
    monthly
    missingok
    rotate 7
    compress
    delaycompress
    notifempty
    create 640 root adm
    sharedscripts
    prerotate
    endscript
    postrotate
        # reload could be not sufficient for all logs, a restart is safer
        /usr/bin/systemctl restart proftpd.service 2>/dev/null >/dev/null || true
    endscript
}
