require github [ user=repology ] postgresql

SUMMARY="A PostgreSQL extension for comparing version strings, based on libversion"

LICENCES="MIT PostgreSQL"
SLOT="0"
PLATFORMS="~amd64"
MYOPTIONS=""

DEPENDENCIES="
    build:
        virtual/pkg-config
    build+run:
        dev-libs/libversion
"

prepare_one_multibuild() {
    default

    postgresql_prepare_one_multilib

    edo sed -i -e "s/pkg-config/$(exhost --tool-prefix)pkg-config/g" Makefile
}

