require github [ tag=v${PV} ]
require postgresql
require v8-bundle [ v8_work=${WORKBASE}/v8 ]

SUMMARY="V8 Engine Javascript Procedural Language add-on for PostgreSQL"

LICENCES="BSD-3"
SLOT="0"

DEPENDENCIES="
    build+run:
        dev-libs/icu:*
"

DEFAULT_SRC_PREPARE_PATCHES=(
    "${FILES}"/bypass-v8-cmake.patch
)

export_exlib_phases src_unpack src_prepare src_compile

plv8_src_unpack() {
    v8-bundle_unpack
    easy-multibuild_src_unpack
}

plv8_src_prepare() {
    v8-bundle_prepare
    easy-multibuild_src_prepare
}

prepare_one_multibuild() {
    default
    postgresql_prepare_one_multilib

    # Link V8 headers from our build
    edo mkdir -p deps/v8-cmake/v8
    edo ln -sf "${V8_WORK}/include" deps/v8-cmake/v8/include
}

plv8_src_compile() {
    v8-bundle_compile
    easy-multibuild_src_compile
}

compile_one_multibuild() {
    emake \
        CUSTOM_CC=$(exhost --tool-prefix)g++ \
        V8_LIB_PATH="${V8_WORK}/out/$(v8_platform).release/obj" \
        all
}

install_one_multibuild() {
    emake CUSTOM_CC=$(exhost --tool-prefix)g++ DESTDIR=${IMAGE} install
}

